## ── Corpus build (bench-build-corpus only) ────────────────────────────────
## Default: embeddings run locally via sentence-transformers (see HF_* below).
## Alternative backends (remote embeddings — separate geometry from Nomic/HF):
##   CORPUS_EMBED_BACKEND=gemini — Google AI Studio API key:
##     pip install -e '.[build-gemini]'  +  GEMINI_API_KEY
##   CORPUS_EMBED_BACKEND=vertex — Vertex AI (ADC, same bill as console):
##     pip install -e '.[build-vertex]'
##     gcloud auth application-default login
##     GCP_PROJECT_ID (or GOOGLE_CLOUD_PROJECT), GCP_LOCATION=us-central1
##     VERTEX_EMBED_MODEL=gemini-embedding-001
##     HF_EMBED_MAX_DIM=3072  (or 768 — maps to outputDimensionality on API)
## Optional throttles: GEMINI_EMBED_PAUSE_S, VERTEX_EMBED_PAUSE_S
##
# CORPUS_EMBED_BACKEND=hf
# GEMINI_API_KEY=""
# GEMINI_EMBED_MODEL=models/text-embedding-004
# GEMINI_EMBED_PAUSE_S=0
# GCP_PROJECT_ID=""
# GCP_LOCATION=us-central1
# VERTEX_EMBED_MODEL=gemini-embedding-001
# VERTEX_EMBED_PAUSE_S=0
##
## HF_EMBED_MODEL — model ID on HuggingFace Hub.
##   Default: nomic-ai/nomic-embed-text-v1.5 (768-dim, Apache 2.0, free).
##   Other MRL-compatible options:
##     mixedbread-ai/mxbai-embed-large-v1   (1024-dim)
##     Snowflake/snowflake-arctic-embed-m-v2.0  (768-dim)
## HF_TOKEN — only required for gated/private models. Leave blank for open models.
## HF_EMBED_MAX_DIM — maximum output dimension to store in corpus/
##   (default 768; set to 1024 if using a 1024-dim model).
## HF_EMBED_DEVICE — optional: mps (Apple GPU), cuda, or cpu. Unset = auto
##   (cuda → mps on Apple Silicon → cpu). Use HF_EMBED_DEVICE=mps to fail
##   fast if Metal is not available. Docker on Mac usually has no GPU.
##
## HF_HOME — Hugging Face cache root (model weights + dataset Arrow files).
##   Default: ~/.cache/huggingface. Docker Compose mounts ./.hf-cache here.
## HF_DATASETS_CACHE — optional override for datasets only (subfolder of HF_HOME if unset).
##
## BENCH_HF_DATASETS_STREAMING — default 1: stream BeIR splits from the Hub when
##   sampling (low disk use; may re-download each corpus build). Set 0 to download
##   splits into the HF cache once and reuse (large first pull for MS MARCO mixed
##   presets; later builds are mostly disk-local). After populating the cache you
##   can use HF_HUB_OFFLINE=1 to forbid network access entirely.
# HF_HOME="${HOME}/.cache/huggingface"
# HF_DATASETS_CACHE=""
# BENCH_HF_DATASETS_STREAMING=0
# HF_EMBED_MODEL="nomic-ai/nomic-embed-text-v1.5"
# HF_TOKEN=""
# HF_EMBED_MAX_DIM=768
HF_EMBED_DEVICE=mps

## ── Embedding dimension (benchmark time) ─────────────────────────────────
## Allowed dims include 256, 512, 768, 1024, 1536, 3072 (must match corpus
## manifest). HF corpora are built at HF_EMBED_MAX_DIM; benchmarks may slice
## prefix + renorm when supported. Vertex Gemini embeddings use HF_EMBED_MAX_DIM
## as API outputDimensionality.
EMBED_DIM=768

## ── Aiven API token (optional — overrides the standalone UI login) ───────
## If set, the standalone NiceGUI dashboard skips the login page and uses
## this token directly. Leave blank to use the UI login form instead
## (recommended for shared containers; the token then lives only in
## browser session state).
##
## When deployed by aiven-bench-orchestrator as the loader API, this is
## ignored — credentials for each target OpenSearch service are sent
## inline with every job request and never persisted on the loader.
# AIVEN_API_TOKEN=""

## ── OpenSearch service URI (headless / CLI-only use) ─────────────────────
## Only needed when running bench-* commands directly from the CLI without
## going through the NiceGUI dashboard. The dashboard resolves the URI from
## the Aiven API automatically.
# OPENSEARCH_URI="https://USER:PASSWORD@HOST:PORT"

## ── Index name ────────────────────────────────────────────────────────────
OPENSEARCH_INDEX="bench"

## ── Benchmark reports: loader / target metadata & preflight ──────────────
## Reports include deployment (plan + cloud) when set explicitly or resolved
## via the Aiven API (requires AIVEN_API_TOKEN + AIVEN_PROJECT).
##
## Loader (benchmark runner host — e.g. Aiven Application):
# BENCH_LOADER_HOSTNAME=""
# BENCH_LOADER_SERVICE_NAME=""
# BENCH_LOADER_PLAN=""
# BENCH_LOADER_CLOUD=""
# BENCH_LOADER_AIVEN_SERVICE_NAME=""
##
## Target OpenSearch (optional API lookup name — overrides parsing URI only):
# BENCH_TARGET_OPENSEARCH_SERVICE_NAME=""
# BENCH_TARGET_OPENSEARCH_PLAN=""
# BENCH_TARGET_OPENSEARCH_CLOUD=""
## If BENCH_TARGET_OPENSEARCH_SERVICE_NAME is unset, AIVEN_SERVICE_NAME is used
## when set (e.g. bench-plan-change CLI).
##
## Preflight: timed HTTPS GET / to the cluster (same auth as OPENSEARCH_URI),
## repeated before each bench-* that hits OpenSearch (not ICMP).
# BENCH_PREFLIGHT_ROUNDS=5
# BENCH_PREFLIGHT_TIMEOUT_S=15
##
## Raw samples: write an additional ``*-raw.json`` next to the summary report
## (per-bulk latencies for bench-index; per-query latencies + IDs for bench-recall).
## Download from the loader via GET /results/<filename> (same as other reports).
# BENCH_SAVE_RAW_SAMPLES=1

## ── Loader API mode (Aiven Application deployment) ───────────────────────
## Set LOADER_MODE=1 to switch the entrypoint from the standalone NiceGUI
## dashboard to the FastAPI loader shim that aiven-bench-orchestrator talks
## to. LOADER_API_KEY is the shared bearer token expected on every request
## except /healthz and /metrics; the orchestrator generates one at deploy
## time. Leave both unset for normal local dashboard use.
# LOADER_MODE=1
# LOADER_API_KEY=""

## ── Data directories (loader API mode) ───────────────────────────────────
## Where the corpus is built and where benchmark reports are written.
## Defaults match the Aiven Application bind-mount layout. Override locally
## (e.g. CORPUS_DIR=./corpus) when running the loader outside Aiven.
# CORPUS_DIR="/data/corpus"
# RESULTS_DIR="/data/results"
